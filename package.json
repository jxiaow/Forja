{
  "name": "forja",
  "displayName": "Forja",
  "publisher": "forja",
  "description": "Build, run, debug C++ projects — Qt (qmake) and SDK (.sln/Makefile) in one extension",
  "version": "0.7.49",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.pro",
    "workspaceContains:**/*.sln",
    "workspaceContains:**/Makefile"
  ],
  "main": "./out/extension.js",
  "bin": {
    "forja": "./out/cli/index.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "forja.config.openPage",
        "title": "Forja: 打开配置页"
      },
      {
        "command": "forja.showActions",
        "title": "Forja: 显示操作菜单"
      },
      {
        "command": "forja.qt.selectProject",
        "title": "Forja Qt: 选择项目"
      },
      {
        "command": "forja.qt.showActions",
        "title": "Forja Qt: 显示操作菜单"
      },
      {
        "command": "forja.qt.qmake",
        "title": "Forja Qt: QMake"
      },
      {
        "command": "forja.qt.build",
        "title": "Forja Qt: Build"
      },
      {
        "command": "forja.qt.clean",
        "title": "Forja Qt: Clean"
      },
      {
        "command": "forja.qt.run",
        "title": "Forja Qt: Run"
      },
      {
        "command": "forja.qt.stop",
        "title": "Forja Qt: 停止"
      },
      {
        "command": "forja.qt.debug",
        "title": "Forja Qt: 调试"
      },
      {
        "command": "forja.qt.openWithQtDesigner",
        "title": "Forja Qt: 用 Qt Designer 打开"
      },
      {
        "command": "forja.syncTestConnection",
        "title": "Forja: 测试远程连接"
      },
      {
        "command": "forja.syncChangedFiles",
        "title": "Forja: 同步变更文件到远程"
      },
      {
        "command": "forja.qt.rcc",
        "title": "Forja Qt: RCC 编译"
      },
      {
        "command": "forja.qt.runCustomCommand",
        "title": "Forja Qt: 执行自定义命令"
      },
      {
        "command": "forja.sdk.build",
        "title": "Forja SDK: Build",
        "enablement": "forja.sdk.activated"
      },
      {
        "command": "forja.sdk.rebuild",
        "title": "Forja SDK: Rebuild",
        "enablement": "forja.sdk.activated"
      },
      {
        "command": "forja.sdk.clean",
        "title": "Forja SDK: Clean",
        "enablement": "forja.sdk.activated"
      },
      {
        "command": "forja.sdk.selectProject",
        "title": "Forja SDK: Select Project",
        "enablement": "forja.sdk.activated"
      },
      {
        "command": "forja.sdk.showActions",
        "title": "Forja SDK: Show Actions",
        "enablement": "forja.sdk.activated"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "forja.qt.openWithQtDesigner",
          "when": "resourceExtname == .ui",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forja",
          "title": "Forja",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "forja": [
        {
          "id": "forja.configView",
          "name": "配置",
          "when": "workspaceFolderCount > 0"
        }
      ]
    }
  },
  "scripts": {
    "copy-html": "node scripts/copy-html.js",
    "compile": "tsc -p ./ && npm run copy-html",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test --test-reporter=spec out/test",
    "lint": "eslint src/",
    "build:cli": "npm run compile && node scripts/build-cli.js",
    "package": "npm run compile && node scripts/package-vs.js",
    "package:cli": "npm run build:cli",
    "package:all": "node scripts/bump-version.js && npm run package && npm run package:cli",
    "release": "node scripts/release.js",
    "vsix": "vsce package --allow-missing-repository",
    "harness:check": "node harness/core/automation/check-harness.js",
    "harness:ops:init": "node harness/core/operations/create-operation-docs.js"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "20.19.37",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "2.32.0",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3"
  }
}
