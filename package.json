{
  "name": "qt-pilot",
  "displayName": "Qt Pilot",
  "publisher": "qtpilot",
  "description": "Build, run, debug, and configure qmake-based Qt/C++ projects in VSCode",
  "version": "0.3.3",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:**/*.pro",
    "onView:qtPilot.configView",
    "onCommand:qtPilot.selectProject",
    "onCommand:qtPilot.showActions",
    "onCommand:qtPilot.qmake",
    "onCommand:qtPilot.build",
    "onCommand:qtPilot.clean",
    "onCommand:qtPilot.run",
    "onCommand:qtPilot.stop",
    "onCommand:qtPilot.debug",
    "onCommand:qtPilot.openWithQtDesigner"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "qtPilot.selectProject", "title": "Qt Pilot: 选择项目" },
      { "command": "qtPilot.showActions",   "title": "Qt Pilot: 显示操作菜单" },
      { "command": "qtPilot.qmake",         "title": "Qt Pilot: QMake" },
      { "command": "qtPilot.build",         "title": "Qt Pilot: Build" },
      { "command": "qtPilot.clean",         "title": "Qt Pilot: Clean" },
      { "command": "qtPilot.run",           "title": "Qt Pilot: Run" },
      { "command": "qtPilot.stop",          "title": "Qt Pilot: 停止" },
      { "command": "qtPilot.debug",         "title": "Qt Pilot: 调试" },
      { "command": "qtPilot.openWithQtDesigner", "title": "Qt Pilot: 用 Qt Designer 打开" }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "qtPilot.openWithQtDesigner",
          "when": "resourceExtname == .ui",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qt-pilot",
          "title": "Qt Pilot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "qt-pilot": [
        {
          "type": "webview",
          "id": "qtPilot.configView",
          "name": "配置"
        }
      ]
    },
    "configuration": {
      "title": "Qt Pilot",
      "properties": {
        "qtPilot.qtPath": {
          "type": "string",
          "default": "",
          "description": "Qt 安装路径（手动指定，留空则自动检测）"
        },
        "qtPilot.designerPath": {
          "type": "string",
          "default": "",
          "description": "Qt Designer 可执行文件路径（可选，优先于自动推断）"
        },
        "qtPilot.vsDevShellPath": {
          "type": "string",
          "default": "",
          "description": "Path to Launch-VsDevShell.ps1 (VsDevCmd.bat will be used automatically)"
        },
        "qtPilot.selectedProject": {
          "type": "string",
          "default": "",
          "description": "当前选中的 .pro 文件记录（扩展内部维护）"
        },
        "qtPilot.arch": {
          "type": "string",
          "default": "x86",
          "enum": ["x86", "x64"],
          "description": "目标架构"
        },
        "qtPilot.mode": {
          "type": "string",
          "default": "debug",
          "enum": ["debug", "release"],
          "description": "构建模式"
        },
        "qtPilot.scanExcludeDirs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "生成 IntelliSense 配置时额外排除的目录名（已内置排除 build*/debug/release）"
        },
        "qtPilot.qmakeTarget": {
          "type": "string",
          "default": "",
          "description": "QMake 时指定的 TARGET 名称（留空则使用 .pro 文件默认值）"
        },
        "qtPilot.cStandard": {
          "type": "string",
          "default": "c11",
          "enum": ["c89", "c99", "c11", "c17"],
          "description": "IntelliSense C 标准版本"
        },
        "qtPilot.cppStandard": {
          "type": "string",
          "default": "c++11",
          "enum": ["c++11", "c++14", "c++17", "c++20", "c++23"],
          "description": "IntelliSense C++ 标准版本"
        },
        "qtPilot.proPath": {
          "type": "string",
          "default": "",
          "description": "（已废弃）请使用 qtPilot.selectedProject"
        },
        "qtPilot.manualProPath": {
          "type": "string",
          "default": "",
          "description": "手动指定 .pro 文件绝对路径（扫描不到时使用）"
        }
      }
    }
  },
  "scripts": {
    "copy-html": "powershell -Command \"Copy-Item -Path src/ui/configPanel/configPanel.html -Destination out/ui/configPanel/ -Force\"",
    "compile": "tsc -p ./ && npm run copy-html",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package --allow-missing-repository",
    "vsix": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
