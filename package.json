{
  "name": "qt-pilot",
  "displayName": "Qt Pilot",
  "publisher": "qtpilot",
  "description": "Build, run, debug, and configure qmake-based Qt/C++ projects in VSCode",
  "version": "0.5.36",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.pro",
    "onView:qtPilot.configView",
    "onCommand:qtPilot.selectProject",
    "onCommand:qtPilot.showActions",
    "onCommand:qtPilot.qmake",
    "onCommand:qtPilot.build",
    "onCommand:qtPilot.clean",
    "onCommand:qtPilot.run",
    "onCommand:qtPilot.stop",
    "onCommand:qtPilot.debug",
    "onCommand:qtPilot.openWithQtDesigner",
    "onCommand:qtPilot.syncTestConnection",
    "onCommand:qtPilot.syncChangedFiles"
  ],
  "main": "./out/extension.js",
  "bin": {
    "qt-pilot": "./out/cli/index.js",
    "qt-pilot-mcp": "./out/mcp/server.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "qtPilot.selectProject",
        "title": "Qt Pilot: 选择项目"
      },
      {
        "command": "qtPilot.showActions",
        "title": "Qt Pilot: 显示操作菜单"
      },
      {
        "command": "qtPilot.qmake",
        "title": "Qt Pilot: QMake"
      },
      {
        "command": "qtPilot.build",
        "title": "Qt Pilot: Build"
      },
      {
        "command": "qtPilot.clean",
        "title": "Qt Pilot: Clean"
      },
      {
        "command": "qtPilot.run",
        "title": "Qt Pilot: Run"
      },
      {
        "command": "qtPilot.stop",
        "title": "Qt Pilot: 停止"
      },
      {
        "command": "qtPilot.debug",
        "title": "Qt Pilot: 调试"
      },
      {
        "command": "qtPilot.openWithQtDesigner",
        "title": "Qt Pilot: 用 Qt Designer 打开"
      },
      {
        "command": "qtPilot.syncTestConnection",
        "title": "Qt Pilot: 测试远程连接"
      },
      {
        "command": "qtPilot.syncChangedFiles",
        "title": "Qt Pilot: 同步变更文件到远程"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "qtPilot.openWithQtDesigner",
          "when": "resourceExtname == .ui",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qt-pilot",
          "title": "Qt Pilot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "qt-pilot": [
        {
          "type": "webview",
          "id": "qtPilot.configView",
          "name": "配置"
        }
      ]
    }
  },
  "scripts": {
    "copy-html": "powershell -Command \"Copy-Item -Path src/ui/configPanel/configPanel.html -Destination out/ui/configPanel/ -Force\"",
    "compile": "tsc -p ./ && npm run copy-html",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test --test-reporter=spec out/test",
    "build:cli": "npm run compile && node scripts/build-cli.js",
    "package": "npm run compile && vsce package --allow-missing-repository -o dist/",
    "package:cli": "npm run build:cli && cd cli && npm pack --pack-destination ../dist",
    "package:all": "node scripts/bump-version.js && npm run package && npm run package:cli",
    "vsix": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
